# -------------------------------------------------------
# Heshma Air Conditioning — Apache Configuration
# -------------------------------------------------------

Options -Indexes

# -------------------------------------------------------
# GZIP Compression
# -------------------------------------------------------

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml
</IfModule>

# -------------------------------------------------------
# Cache-Control — static assets
# -------------------------------------------------------

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/svg+xml         "access plus 1 year"
    ExpiresByType image/x-icon          "access plus 1 year"
    ExpiresByType text/css              "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2            "access plus 1 year"
    ExpiresByType font/woff             "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(webp|png|jpg|jpeg|ico|svg|woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

RewriteEngine On

# Redirect old domain heshmaair.com → heshmaairconditioning.com (before HTTPS rule = 1 hop)
RewriteCond %{HTTP_HOST} ^(www\.)?heshmaair\.com$ [NC]
RewriteRule ^ https://heshmaairconditioning.com%{REQUEST_URI} [L,R=301]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force non-www
RewriteCond %{HTTP_HOST} ^www\.heshmaairconditioning\.com [NC]
RewriteRule ^ https://heshmaairconditioning.com%{REQUEST_URI} [L,R=301]

# -------------------------------------------------------
# 301 Redirects — dead pages from old site
# -------------------------------------------------------

RewriteRule ^projects/?$ /gallery.html [L,R=301]
RewriteRule ^residential-hvac/?$ /ac-repair-forney-tx.html [L,R=301]
RewriteRule ^services/?$ /index.html [L,R=301]

# -------------------------------------------------------
# Custom 404
# -------------------------------------------------------

ErrorDocument 404 /404.html
